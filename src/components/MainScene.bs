    m.focusArea = "cta"
    m.focusIndex = 0
    m.focusRow = 0
    m.menuIndex = 0
    m.menuIds = ["home", "live", "hosts", "featured", "ondemand", "search", "about"]
    m.menuLabels = ["Home", "Live TV", "Hosts", "Featured", "On-demand", "Search", "About"]
    m.menuRailIconUris = [
        "pkg:/images/nav/home.png",
        "pkg:/images/nav/live.png",
        "pkg:/images/nav/hosts.png",
        "pkg:/images/nav/featured.png",
        "pkg:/images/nav/vod.png",
        "pkg:/images/nav/search.png",
